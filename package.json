{
  "name": "omni-scrub",
  "version": "1.0.0",
  "description": "Omni-Scrub - Autonomous Floor Cleaning Robot",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cp src/public/index.html dist/public/index.html && cp dist/server.js ../omni-scrub/server.js",
    "start": "node dist/server.js",
    "start:root": "node omni-scrub/server.js",
    "deploy": "npm run build && scp -r dist/* user@uno-q:/home/root/omni-scrub/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}
